version 3
run MultiplePairs-UDP-D2D-wReuse-0-20260709-21:29:20-650456
attr configname MultiplePairs-UDP-D2D-wReuse
attr datetime 20260709-21:29:20
attr datetimef 20260709-212920
attr experiment MultiplePairs-UDP-D2D-wReuse
attr inifile omnetpp.ini
attr iterationvars $numPairs=5
attr iterationvarsd numPairs=5
attr iterationvarsf numPairs=5-
attr measurement $numPairs=5
attr network simu5g.simulations.lte.networks.SingleCell_D2D
attr processid 650456
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 0
attr seedset 0
itervar numPairs 5
config **.param-recording false
config image-path /home/andras/projects/Simu5G-fork/simu5g-fork/images
config output-scalar-file results/omnetpp.ini-MultiplePairs-UDP-D2D-wReuse-#0.sca
config output-scalar-precision 17
config output-vector-file results/omnetpp.ini-MultiplePairs-UDP-D2D-wReuse-#0.vec
config output-vector-precision 17
config record-eventlog false
config sim-time-limit 5s
config extends MultiplePairs-UDP-D2D
config *.eNB.cellularNic.mac.schedulingDisciplineUl "\"ALLOCATOR_BESTFIT\""
config *.eNB.cellularNic.mac.reuseD2D true
config *.eNB.cellularNic.mac.conflictGraphUpdatePeriod 1s
config *.eNB.cellularNic.mac.conflictGraphThreshold 90
config extends MultiplePairs-UDP-Infra
config *.eNB*.cellularNic.typename LteNicEnbD2D
config *.ueD2D*[*].cellularNic.typename LteNicUeD2D
config **.amcMode "\"D2D\""
config *.ueD2D*[*].cellularNic.d2dInitialMode true
config *.eNB.cellularNic.phy.enableD2DCqiReporting true
config **.usePreconfiguredTxParams false
config **.d2dCqi 7
config extends MultiplePairs
config *.ueD2D*[*].numApps 1
config *.ueD2DTx[*].app[*].typename VoipSender
config *.ueD2DTx[*].app[*].localPort 3088+ancestorIndex(0)
config *.ueD2DTx[*].app[*].startTime uniform(0s,0.02s)
config *.ueD2DTx[*].app[*].destAddress "\"ueD2DRx[\" + string(ancestorIndex(1)) + \"]\""
config *.ueD2DTx[*].app[*].destPort 1000
config *.ueD2DRx[*].app[*].typename VoipReceiver
config *.ueD2DRx[*].app[*].localPort 1000
config *.eNB*.cellularNic.typename LteNicEnb
config *.ueD2D*[*].cellularNic.typename LteNicUe
config **.amcMode "\"AUTO\""
config network simu5g.simulations.lte.networks.SingleCell_D2D
config *.eNB.mobility.initFromDisplayString false
config *.eNB.mobility.initialX 300m
config *.eNB.mobility.initialY 300m
config *.numUeCell 0
config *.numUeD2DTx 5
config *.numUeD2DRx 5
config *.ue*[*].macCellId 1
config *.ue*[*].masterId 1
config *.ue*[*].mobility.initFromDisplayString false
config *.ueD2D*[*].mobility.initialX uniform(290m,310m)
config *.ueD2D*[*].mobility.initialY uniform(340m,350m)
config sim-time-limit 5s
config warmup-period 0s
config repeat 3
config **.routingRecorder.enabled false
config output-scalar-file results/MultiplePairs-UDP-D2D-wReuse/0.sca
config output-vector-file results/MultiplePairs-UDP-D2D-wReuse/0.vec
config seed-set 0
config **.vector-recording true
config **.mobility.constraintAreaMinZ 0m
config **.mobility.constraintAreaMaxZ 0m
config **.numBands 50
config *.configurator.config "xmldoc(\"./demo.xml\")"

