config **.ue11.app[1].typename VoipSender
config **.ue11.app[1].startTime uniform(0s,0.02s)
config **.ue22.app[1].typename VoipReceiver
config **.ue22.app[1].localPort 1000
config **.ue*.app[0].typename UdpVideoStreamClient
config **.ue*.app[0].serverAddress "\"server\""
config **.ue*.app[0].localPort 9999
config **.ue*.app[0].serverPort 3088
config **.ue*.app[0].startTime 0s
config **.server.app[*].typename UdpVideoStreamServer
