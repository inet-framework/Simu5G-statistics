config network simu5g.simulations.lte.networks.MultiCell
config description "4 Ues downloading a video from a server while 2 of them having a voip session (ue11 and ue22)."
config **.ue11.numApps 2
config **.ue22.numApps 2
config **.ue12.numApps 1
config **.ue21.numApps 1
