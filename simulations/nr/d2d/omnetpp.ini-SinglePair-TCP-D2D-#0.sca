config *.ueD2DTx[0].app[*].localPort 1000
config *.ueD2DTx[0].app[*].sendBytes 1GiB
config *.ueD2DTx[0].app[0].active true
config *.ueD2DTx[0].app[0].tOpen uniform(0.010s,0.1s)
