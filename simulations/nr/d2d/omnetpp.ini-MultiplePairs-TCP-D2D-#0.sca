version 3
run MultiplePairs-TCP-D2D-0-20260712-21:00:04-252998
attr configname MultiplePairs-TCP-D2D
attr datetime 20260712-21:00:04
attr datetimef 20260712-210004
attr experiment MultiplePairs-TCP-D2D
attr inifile omnetpp.ini
attr iterationvars $numPairs=5
attr iterationvarsd numPairs=5
attr iterationvarsf numPairs=5-
attr measurement $numPairs=5
attr network simu5g.simulations.nr.networks.SingleCell_Standalone_D2D
attr processid 252998
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 0
attr seedset 0
itervar numPairs 5
config **.param-recording false
config image-path /home/andras/projects/Simu5G-fork/simu5g-fork/images
config output-scalar-file results/omnetpp.ini-MultiplePairs-TCP-D2D-#0.sca
config output-scalar-precision 17
config output-vector-file results/omnetpp.ini-MultiplePairs-TCP-D2D-#0.vec
config output-vector-precision 17
config record-eventlog false
config sim-time-limit 20s
config extends MultiplePairs-TCP-Infra
config *.ueD2D*[*].cellularNic.d2dInitialMode true
config **.amcMode "\"D2D\""
config **.gnb.cellularNic.phy.enableD2DCqiReporting true
config **.usePreconfiguredTxParams false
config **.d2dCqi 7
config extends MultiplePairs
config **.vector-recording true
config *.ueD2D*[*].numApps 1
config *.ueD2DTx[*].app[*].typename TcpSessionApp
config *.ueD2DTx[*].app[*].connectPort 1000
config *.ueD2DTx[*].app[*].localPort 1000
config *.ueD2DTx[*].app[*].sendBytes 1GiB
config *.ueD2DTx[*].app[*].active true
config *.ueD2DTx[*].app[*].tOpen uniform(0.010s,0.1s)
config *.ueD2DTx[*].app[*].tSend uniform(0.15s,0.5s)
config *.ueD2DTx[*].app[*].connectAddress "\"ueD2DRx[\" + string(ancestorIndex(1)) + \"]\""
config *.ueD2DTx[*].app[*].localAddress "\"ueD2DTx[\" + string(ancestorIndex(1)) + \"]\""
config *.ueD2DRx[*].app[*].typename TcpSinkApp
config *.ueD2DRx[*].app[*].localPort 1000
config **.app[*].tClose -1s
config network simu5g.simulations.nr.networks.SingleCell_Standalone_D2D
config *.gnb.mobility.initialX 300m
config *.gnb.mobility.initialY 300m
config *.numUeCell 0
config *.numUeD2DTx 5
config *.numUeD2DRx 5
config *.ue*[*].servingNodeId 0
config *.ue*[*].nrServingNodeId 1
config *.ueD2D*[*].mobility.initialX uniform(290m,310m)
config *.ueD2D*[*].mobility.initialY uniform(340m,350m)
config sim-time-limit 20s
config warmup-period 0s
config repeat 3
config **.routingRecorder.enabled false
config output-scalar-file results/MultiplePairs-TCP-D2D/0.sca
config output-vector-file results/MultiplePairs-TCP-D2D/0.vec
config seed-set 0
config **.vector-recording false
config **.mobility.constraintAreaMaxX 1000m
config **.mobility.constraintAreaMaxY 1000m
config **.mobility.constraintAreaMinX 0m
config **.mobility.constraintAreaMinY 0m
config **.mobility.constraintAreaMinZ 0m
config **.mobility.constraintAreaMaxZ 0m
config **.mobility.initFromDisplayString false
config **.numBands 50
config **.ueTxPower 26dBm
config **.eNodeBTxPower 40dBm
config **.targetBler 0.01
config **.blerShift 5
config *.configurator.config "xmldoc(\"./demo.xml\")"

