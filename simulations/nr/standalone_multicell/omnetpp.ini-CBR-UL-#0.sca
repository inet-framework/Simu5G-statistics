config record-eventlog false
config sim-time-limit 20s
config extends MultiCell
config description "CBR UL traffic from UEs to remote server"
config *.ue[*].numApps 1
config *.server.numApps 1
config *.server.app[*].typename CbrReceiver
config *.server.app[*].localPort "3000 + ancestorIndex(0)"
config *.ue[*].app[*].typename CbrSender
config *.ue[*].app[*].packetSize 100B
