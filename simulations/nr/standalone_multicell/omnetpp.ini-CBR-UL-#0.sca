config *.ue[*].app[*].destAddress "\"server\""
config *.ue[*].app[*].destPort "3000 + ancestorIndex(1)"
config *.ue[*].app[*].localPort 3088+ancestorIndex(0)
config *.ue[*].app[*].startTime uniform(0s,0.02s)
config *.ue[*].app[*].finishTime uniform(19.9s,19.92s)
config network simu5g.simulations.nr.networks.MultiCell_Standalone
config sim-time-limit 20s
config description "Base configuration, do not run this config!"
