config record-eventlog false
config sim-time-limit 50s
config extends "MultiCarrier, CBR-DL"
config *.carrierAggregation.numComponentCarriers 2
config *.carrierAggregation.componentCarrier[0].carrierFrequency 2GHz
config *.carrierAggregation.componentCarrier[0].numBands 6
config *.carrierAggregation.componentCarrier[1].carrierFrequency 6GHz
config *.carrierAggregation.componentCarrier[1].numBands 6
config *.gnb.cellularNic.numCarriers 2
config *.gnb.cellularNic.channelModel[0].componentCarrierModule "\"carrierAggregation.componentCarrier[0]\""
config *.gnb.cellularNic.channelModel[1].componentCarrierModule "\"carrierAggregation.componentCarrier[1]\""
config *.ue[*].cellularNic.numNrCarriers 2
config *.ue[*].cellularNic.nrChannelModel[0].componentCarrierModule "\"carrierAggregation.componentCarrier[0]\""
config *.ue[*].cellularNic.nrChannelModel[1].componentCarrierModule "\"carrierAggregation.componentCarrier[1]\""
config *.ue[*].app[*].typename CbrReceiver
config *.ue[*].app[*].localPort 1000
config *.server.app[*].samplingTime 0.02s
config *.server.app[*].destAddress "\"ue[\"+string(ancestorIndex(0))+\"]\""
config *.server.app[*].destPort 1000
config *.server.app[*].localPort 3088+ancestorIndex(0)
config *.server.app[*].typename CbrSender
config *.server.app[*].startTime uniform(0.01s,0.02s)
config *.server.app[*].packetSize 2000B
config sim-time-limit 50s
config network simu5g.simulations.nr.networks.SingleCell_Standalone
config **.routingRecorder.enabled false
config seed-set 0
config **.sctp.**.scalar-recording false
config **.sctp.**.vector-recording false
config **.vector-recording true
config **.mobility.constraintAreaMinZ 0m
config **.mobility.constraintAreaMaxZ 0m
config **.mobility.initFromDisplayString false
config **.eNodeBTxPower 40dBm
config **.sctp.nagleEnabled false
config **.sctp.enableHeartbeats false
config **.downlinkInterference true
config **.uplinkInterference true
config **.enableHandover true
config **.fbPeriod 10tti
config **.targetBler 0.01
config **.blerShift 5
config *.configurator.config "xmldoc(\"./demo.xml\")"
config *.gnb.mobility.initialX 300m
config *.gnb.mobility.initialY 300m
config *.numUe 10
config *.ue[*].servingNodeId 0
config *.ue[*].nrServingNodeId 1
config **.mobility.constraintAreaMaxX 700m
config **.mobility.constraintAreaMaxY 400m
config **.mobility.constraintAreaMinX 100m
